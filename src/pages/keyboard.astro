---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import TypingStats from "../components/TypingStats.astro";
const description = "serene's keyboard & typing stats";
const frontmatter = {
    title: 'keyboard',
    citation: {
        url: 'https://api.shojo.me/monkeytype.json',
        name: 'api.shojo.me'
    },
    backlink: {
        url: '/#typing',
        name: '/home'
    },
    timestamp: '0 hours ago'
}
---

<ArticleLayout frontmatter={frontmatter}, description={description}>
    <TypingStats />
</ArticleLayout>
