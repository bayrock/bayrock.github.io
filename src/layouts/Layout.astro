---
import { ClientRouter } from 'astro:transitions';
import { fade } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.pcss';
import { avatar } from '../../custom.config.mjs';
const favicon = `https://avatars.githubusercontent.com/u/${avatar.githubID}?s=${avatar.size}`
const { title, description } = Astro.props;
const content = description?.replace(/<\/?[^>]+(>|$)/g, "").trim();
---
<!DOCTYPE html>
<html transition:animate="none" lang="en">
	<head>
        <meta charset="utf-8" />
        <meta name="description" content={content || "bayrock's domain"}>
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" id="favicon" href={favicon} />     
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
	</head>
	<body>
        <Header />
        <main transition:animate={fade({ duration: '0.2s' })} >
            <slot />
        </main>
        <Footer />
	</body>
</html>

<script>
    const colorMode = () => {
        if (localStorage.theme === "light" )
            document.documentElement.classList.add("light");
        else
            document.documentElement.classList.remove("light");
    }
    
    document.addEventListener('astro:after-swap', colorMode);
</script>
