---
const model = "Apple Magic"
const switches = "Scissor"
const layout = "QWERTY"
---
<section id="specs" class="flex">
    <img width="30" height="35" src="/icons/apple.svg" alt="model"> <span class="flex column">Model <small class="gray">{model}</small></span><hr>
    <img width="22" height="34" class="invert-white" src="/icons/switch.svg" alt="switch"> <span class="flex column">Switch <small class="gray">{switches}</small></span><hr>
    <img width="38" height="32" class="invert-white" src="/icons/keyboard.svg" alt="layout"> <span class="flex column">Layout <small class="gray">{layout}</small></span>
</section>
<section id="details" class="flex" style="justify-content: space-between;">
    <section id="statistics">
        <h2>statistics</h2>
        <ul class="badge__list">
            <li><span class="badge badge--item">passed</span> <b><span id="passedElement" class="text-loader">0000</span></b> tests <span class="accent">✔</span></li>
            <li><span class="badge badge--item">failed</span> <b><span id="failedElement" class="text-loader">00000</span></b> tests <span style="color: red;">𝐱</span></li>
            <li><span class="badge badge--item">typed</span> <b><span id="timeElement" class="text-loader">00</span></b> hours <span class="gray">⏰</span></li>
        </ul>
    </section>
    <section id="speed">
        <h2>speed</h2>
        <ul class="badge__list">
            <li><span class="badge badge--item">wpm</span> <b><span id="qwertyElement" class="text-loader">000</span></b> <span class="gray">⌨</span></li>
        </ul>
        <h2>streak</h2>
        <ul class="badge__list">
            <li><span class="badge badge--item">days</span> <b><span id="streakElement" class="text-loader">000</span></b> <span class="gray">🔥</span></li>
        </ul>
    </section>
</section>

<style>
    hr { margin-left: 8px; }

    #specs {
        font-family: var(--body);
        padding-top: 15px;
        align-self: center;
    }

    .flex > img { padding: 0 12px; }

    @media only screen and (min-width: 600px) {
        hr { margin-left: auto; }
    }
</style>

<script>
    import { secondsToHours, millisecondsToSeconds } from "../modules/getTimeConversion";
    import getTimeString from "../modules/getTimeString";

    const getMonkeyData = async () => {
        try {
            const response = await fetch("https://api.shojo.me/monkeytype");

            if (!response.ok)
                throw new Error(`Error: ${response.status} - ${response.statusText}`);

            return await response.json();
        } catch (error) {
            console.error(error);
        }
    }

    const updateData = async (data) => {
        // Get data
        const { qwerty, timestamp } = data;
        const completedTests = qwerty.stats.completedTests;
        const failedTests = qwerty.stats.startedTests - completedTests;
        const timeTyping = Math.ceil(secondsToHours(qwerty.stats.timeTyping));
        const qwertyWPM = Math.ceil(qwerty.bests.words[10][0].wpm);
        const streak = qwerty.streak;
        const lastUpdated = getTimeString(Math.ceil(millisecondsToSeconds(Date.now()) - Math.floor(millisecondsToSeconds(timestamp))));
        
        // Get elements
        const passedElement = document.getElementById("passedElement");
        const failedElement = document.getElementById("failedElement");
        const timeElement = document.getElementById("timeElement");
        const qwertyElement = document.getElementById("qwertyElement");
        const streakElement = document.getElementById("streakElement");
        const timestampElement = document.getElementById("timestampElement");

        // Set data to elements
        if (passedElement) passedElement.innerHTML = completedTests;
        if (failedElement) failedElement.innerHTML = failedTests;
        if (timeElement) timeElement.innerHTML = timeTyping;
        if (qwertyElement) qwertyElement.innerHTML = qwertyWPM;
        if (streakElement) streakElement.innerHTML = streak;
        if (timestampElement) timestampElement.innerHTML = lastUpdated;

        // Remove loaders
        document.querySelectorAll(".text-loader").forEach((e) => {
            e.classList.remove("text-loader");
        });
    }

    const data = await getMonkeyData();
    updateData(data);
    document.addEventListener('astro:page-load', () => { updateData(data) });
</script>
